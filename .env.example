# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (Supabase) ──────────────────────────────────
# Get these from: Supabase → Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Session" mode URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars-long"
JWT_EXPIRES_IN=7d

# ── Cloudinary ───────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ───────────────────────────────────────
# Get this from: resend.com → API Keys
RESEND_API_KEY=re_your_api_key
CONTACT_EMAIL=your@email.com

# ── Client ───────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Client-side (prefix with VITE_) ─────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_MAPTILER_KEY=your_maptiler_key
